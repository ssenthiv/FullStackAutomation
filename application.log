//<![CDATA[

		var _leftPanel = new Object();
		
		_leftPanel.panelArray = new Array("EMAIL", "OWNER", "SAVE", "LOAD", "EXPORT", "SUBSCRIBE", "SLOWNER");
		
		_leftPanel.confirmAction = function() {
			oFrm = document.left_panel_control;
			if (oFrm.doaction.value =='DELETE') {
				if (!confirm('Are you sure you want to delete selected records from the database? \nYou cannot undo this operation.\nTo remove items from the short list, use the Remove action.')) {
					return false;
				} 
			} 
			return true;
		}
		
		_leftPanel.openWin = function (url, name, param) {
			newwin = window.open(url, name, param);
			newwin.focus();
		}

			
		_leftPanel.expandPanel = function() {
			parent.document.body.cols="120,*";
			parent.mainpanel.left_panel_state = true;
		}
		
		_leftPanel.proOnlyAlert = function() {
		  alert('This option is only available in the professional version');
		}
		
		_leftPanel.evalAction = function(obj) {
			act = obj.value;
			if (act == 'EMAIL') {
				_leftPanel.showPanel(act);
			} else if (act == 'SUBSCRIBE') {
				_leftPanel.showPanel(act);
			} else if (act == 'SLOWNER') {
				_leftPanel.showPanel(act);
			} else if (act == 'SAVE') {
				_leftPanel.showPanel(act);
			} else if (act == 'LOAD' || act == 'DELSS') {
				_leftPanel.showPanel('LOAD');
				_leftPanel.proOnlyAlert();
			} else if (act == 'OWNER') {
				_leftPanel.showPanel('OWNER');
			} else if (act=='UPDATE') {
				top.window.frames["mainpanel"].document.location='https://www.freecrm.com/system/index.cfm?action=user&sub=massupdate&updateObjectName=';
				_leftPanel.showPanel('UPDATE');	
			} else if (act == 'EXPORT') {
				_leftPanel.showPanel('EXPORT');
			} else {
				_leftPanel.hideAllPanels();
			}
		}	
	
		_leftPanel.showPanel = function(pnl) {
			_leftPanel.hideAllPanels();
			document.getElementById(pnl).style.display='inline'; 
		}

		_leftPanel.hideAllPanels = function() {
			for (var i=0; i<_leftPanel.panelArray.length; i++) {
				document.getElementById(_leftPanel.panelArray[i]).style.display='none'; 
			}
		}
		VoiceCRMCallPanel = function vcc() {
			return {
				init: function(container) {
					this.container = container || window.top.frames[1];
					this.startTime = new Date();
				},
				show: function() {
					var self = this;
					this.panel = document.createElement('DIV');
					this.panel.setAttribute('class','webrtccall-control');
					// this.panel.style.width = 300;
					// this.panel.style.height = 60;
					// this.panel.style.left = 400;
					// this.panel.style.top = 10;
					// this.panel.style.position = 'absolute';
					// this.panel.style.background='silver';
					// this.panel.style.border = '1px solid black';
					//this.panel.innerHTML = '<h1><a href="javascript: VoiceCRM.SipCaller.hangUp();">Hang Up</a></h1>';
					var button = document.createElement('input');
					button.type='button';
					button.value = 'HANG UP';
					this.container.bindEvent('click', button, function() {
						console.log("HANG IT");
						self.container.VoiceCRM.SipCaller.hangUp(self);
					});
					var timer = document.createElement('input');
					timer.type='text';
					timer.readOnly = true;
					timer.width=20;
					this.intervalId = window.setInterval(function() {
						var timerText = new Date(new Date-self.startTime).toTimeString();
						timer.value = timerText.split(' ')[0];
					}, 1000);
					this.panel.appendChild(button);
					this.panel.appendChild(timer);
					this.container.document.body.appendChild(this.panel);
					this.container.Drag.init(this.panel);
				},
				setContent: function(content) {
					this.panel.innerHTML = content;
				},
				close: function() {
					window.clearInterval(this.intervalId);
					this.container.document.body.removeChild(this.panel);
				}
			}
		}
	
//]]>
</script>

